# API Keys (Required)
TAVILY_API_KEY=your_tavily_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Database Configuration
DATABASE_URL=sqlite:///./api_discovery.db
# For PostgreSQL: postgresql://user:password@localhost/api_discovery
# For MySQL: mysql://user:password@localhost/api_discovery

# Redis Configuration (Optional - for caching)
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_DB=0

# Application Settings
APP_NAME=API Discovery & Auth Service
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO
SECRET_KEY=your-secret-key-here-change-this-in-production

# Browser Automation Settings
BROWSER_HEADLESS=true
BROWSER_TIMEOUT=60
MAX_SIGNUP_ATTEMPTS=3
BROWSER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# API Discovery Settings
MAX_SEARCH_RESULTS=10
SEARCH_TIMEOUT=30
DEFAULT_SEARCH_DEPTH=advanced
INCLUDE_RAW_CONTENT=true

# Rate Limiting
REQUESTS_PER_MINUTE=60
BURST_LIMIT=10
RATE_LIMIT_ENABLED=true

# Caching Settings
CACHE_TTL=3600
MAX_CACHE_SIZE=1000
CACHE_ENABLED=true

# Security Settings
ENCRYPT_API_KEYS=true
API_KEY_ENCRYPTION_KEY=your-encryption-key-here
SESSION_TIMEOUT=3600

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=true

# Monitoring and Analytics
ENABLE_METRICS=true
METRICS_PORT=8001
SENTRY_DSN=

# Development Settings
RELOAD=false
WORKERS=1
HOST=0.0.0.0
PORT=8000 